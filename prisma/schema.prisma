generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  phone     String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  bookings  Booking[]
  waitlists Waitlist[]

  @@map("users")
}

model TimeSlot {
  id               Int            @id @default(autoincrement())
  date             DateTime       @db.Date
  startTime        String
  endTime          String
  isBlocked        Boolean        @default(false)
  blockedReason    String?
  bookings         Booking[]      @relation("BookingSlot")
  originalBookings Booking[]      @relation("OriginalSlot")
  waitlists        Waitlist[]
  guestBookings    GuestBooking[]

  @@unique([date, startTime])
  @@map("time_slots")
}

model Booking {
  id             Int           @id @default(autoincrement())
  userId         Int
  slotId         Int
  status         BookingStatus @default(PENDING)
  note           String?
  rescheduledAt  DateTime?
  originalSlotId Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User      @relation(fields: [userId], references: [id])
  slot         TimeSlot  @relation("BookingSlot", fields: [slotId], references: [id])
  originalSlot TimeSlot? @relation("OriginalSlot", fields: [originalSlotId], references: [id])

  @@map("bookings")
}

model Waitlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  slotId    Int
  position  Int
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id])
  slot TimeSlot @relation(fields: [slotId], references: [id])

  @@unique([userId, slotId])
  @@map("waitlists")
}

model GuestBooking {
  id          Int           @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String
  phone       String
  slotId      Int
  status      BookingStatus @default(PENDING)
  cancelToken String        @unique @default(cuid())
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  slot TimeSlot @relation(fields: [slotId], references: [id])

  @@map("guest_bookings")
}

model ShopHoliday {
  id     Int      @id @default(autoincrement())
  date   DateTime @unique @db.Date
  reason String?

  @@map("shop_holidays")
}
